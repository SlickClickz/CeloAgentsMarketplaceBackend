{
  "name": "celo-agent-marketplace",
  "version": "1.0.0",
  "description": "CAM - Celo Agent Marketplace: open discovery and coordination infrastructure for autonomous agents on Celo",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "backfill": "ts-node scripts/backfill.ts",
    "test:score": "ts-node scripts/testScore.ts",
    "graph:codegen:mainnet": "graph codegen subgraph/subgraph.mainnet.yaml --output-dir subgraph/generated",
    "graph:codegen:testnet": "graph codegen subgraph/subgraph.testnet.yaml --output-dir subgraph/generated",
    "graph:build:mainnet": "graph build subgraph/subgraph.mainnet.yaml",
    "graph:build:testnet": "graph build subgraph/subgraph.testnet.yaml",
    "graph:deploy:mainnet": "graph deploy --studio cam-registry-mainnet subgraph/subgraph.mainnet.yaml",
    "graph:deploy:testnet": "graph deploy --studio cam-registry-testnet subgraph/subgraph.testnet.yaml"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "node-cron": "^3.0.3",
    "thirdweb": "^5.0.0",
    "viem": "^2.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
